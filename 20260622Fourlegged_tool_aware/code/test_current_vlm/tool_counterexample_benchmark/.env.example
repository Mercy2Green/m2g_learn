# Alibaba Cloud Bailian / DashScope OpenAI-compatible
# 推荐在阿里云百炼控制台查看 WorkspaceId 和地域，然后填写 base_url。
BAILIAN_API_KEY=
BAILIAN_BASE_URL=https://{WorkspaceId}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1

# 兼容旧 DashScope 域名时可用；优先使用 BAILIAN_API_KEY/BAILIAN_BASE_URL
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional platforms
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

ARK_API_KEY=
ARK_BASE_URL=

# Optional official APIs
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# Ollama local inference
# Start Ollama before running local models:
#   ollama serve
# Pull candidate VLMs:
#   ollama pull qwen3-vl:8b
#   ollama pull qwen3-vl:4b
#   ollama pull gemma3:12b
OLLAMA_BASE_URL=http://localhost:11434
